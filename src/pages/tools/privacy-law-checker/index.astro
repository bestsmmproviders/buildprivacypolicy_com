  }
  .reset-btn {
    margin-top: 20px;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    font-family: inherit;
    color: #374151;
    background: white;
    border: 1px solid #D1D5DB;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .reset-btn:hover {
    background: #F9FAFB;
  }

  /* FAQ */
  .faq-list {
    margin-top: 8px;
  }
  .faq-item {
    border-top: 1px solid #E5E7EB;
    padding-top: 20px;
    margin-bottom: 8px;
  }
