<script>
  document.addEventListener('DOMContentLoaded', function() {
    var state = { eu: false, california: false, canada: false, brazil: false, children: false };
    var platformSelect = document.getElementById('platform-select');
    var checkBtn = document.getElementById('check-btn');
    var resetBtn = document.getElementById('reset-btn');
    var resultsDiv = document.getElementById('results');
    var resultsList = document.getElementById('results-list');
    var formDiv = document.getElementById('checker-form');

    var laws = {
      gdpr: {
        name: 'GDPR (General Data Protection Regulation)',
        region: 'European Union / EEA',
        description: 'The GDPR requires you to have a lawful basis for processing personal data, provide clear privacy disclosures, honor user rights to access, correct, and delete their data, and report data breaches within 72 hours. Penalties can reach 20 million euros or 4% of global annual revenue.'
      },
      ccpa: {
        name: 'CCPA / CPRA (California Consumer Privacy Act / California Privacy Rights Act)',
        region: 'California, United States',
        description: 'The CCPA/CPRA gives California residents the right to know what personal data is collected, request its deletion, and opt out of its sale or sharing. You must provide a "Do Not Sell Or Share My Personal Information" link and disclose data practices in your privacy policy.'
      },
      pipeda: {
        name: 'PIPEDA (Personal Information Protection and Electronic Documents Act)',
        region: 'Canada',
        description: 'PIPEDA requires you to obtain meaningful consent before collecting personal information, limit collection to what is necessary, and allow individuals to access and correct their data. You must also appoint a privacy officer and maintain transparent data-handling practices.'
      },
      lgpd: {
        name: 'LGPD (Lei Geral de Protecao de Dados)',
        region: 'Brazil',
        description: 'The LGPD requires a legal basis for processing personal data, mandates clear disclosure of data practices, and grants users rights to access, correct, anonymize, and delete their information. Non-compliance can result in fines of up to 2% of revenue in Brazil, capped at 50 million reais per violation.'
      },
      coppa: {
        name: 'COPPA (Children\'s Online Privacy Protection Act)',
        region: 'United States (children under 13)',
        description: 'COPPA requires verifiable parental consent before collecting personal information from children under 13, limits data collection to what is reasonably necessary, and mandates a clear privacy policy describing your practices regarding children\'s data. Violations can result in FTC enforcement actions and fines.'
      }
    };

    // Toggle button handling
    document.querySelectorAll('.toggle-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var field = this.getAttribute('data-field');
        var value = this.getAttribute('data-value');
        var wrap = this.parentElement;
        wrap.querySelectorAll('.toggle-btn').forEach(function(b) { b.classList.remove('active'); });
        this.classList.add('active');
        state[field] = value === 'yes';
        updateCheckBtn();
      });
    });

    // Enable check button when platform is selected
    platformSelect.addEventListener('change', function() {
      updateCheckBtn();
    });

    function updateCheckBtn() {
      checkBtn.disabled = !platformSelect.value;
    }

    // Check button
    checkBtn.addEventListener('click', function() {
      var applicable = [];

      if (state.eu) applicable.push('gdpr');
      if (state.california) applicable.push('ccpa');
      if (state.canada) applicable.push('pipeda');
      if (state.brazil) applicable.push('lgpd');
      if (state.children) applicable.push('coppa');

      resultsList.innerHTML = '';

      if (applicable.length === 0) {
        resultsList.innerHTML = '<div class="result-card result-none">' +
          '<p class="result-none-text"><strong>Based on your answers, none of the five major privacy laws checked by this tool are triggered.</strong></p>' +
          '<p>However, your app or website may still be subject to other regulations not covered here. Many jurisdictions have their own privacy requirements, and app stores like Google Play and the Apple App Store require a privacy policy regardless of which laws apply. We recommend <a href="https://buildprivacypolicy.com/">generating a privacy policy</a> to cover your bases.</p>' +
          '</div>';
      } else {
        applicable.forEach(function(key) {
          var law = laws[key];
          var card = document.createElement('div');
          card.className = 'result-card';
          card.innerHTML = '<div class="result-badge">' + law.region + '</div>' +
            '<h3 class="result-law-name">' + law.name + '</h3>' +
            '<p class="result-description">' + law.description + '</p>';
          resultsList.appendChild(card);
        });

        var ctaDiv = document.createElement('div');
        ctaDiv.className = 'result-cta';
        ctaDiv.innerHTML = '<p>Now that you know which laws apply, <a href="https://buildprivacypolicy.com/">generate your privacy policy</a> to create a compliant document that covers each of these regulations.</p>';
        resultsList.appendChild(ctaDiv);
      }

      formDiv.style.display = 'none';
      resultsDiv.style.display = 'block';
      resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // Reset
    resetBtn.addEventListener('click', function() {
      state = { eu: false, california: false, canada: false, brazil: false, children: false };
      platformSelect.value = '';
      document.querySelectorAll('.toggle-btn[data-value="no"]').forEach(function(btn) {
        btn.classList.add('active');
      });
      document.querySelectorAll('.toggle-btn[data-value="yes"]').forEach(function(btn) {
        btn.classList.remove('active');
      });
      checkBtn.disabled = true;
      resultsDiv.style.display = 'none';
      formDiv.style.display = 'block';
      formDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>

</Layout>

