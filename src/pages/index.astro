---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<!-- Sticky Header -->
<div class="sticky-header">
  <div class="header-left">
    <a href="/" class="logo-link">
      <svg class="logo-icon" width="28" height="28" viewBox="0 0 128 128" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="128" height="128" rx="28" fill="#1E3A5F"/><path d="M64 24C64 24 40 34 32 38V62C32 82 46 98 64 104C82 98 96 82 96 62V38C88 34 64 24 64 24Z" fill="#2E5A8F" stroke="#5B9BD5" stroke-width="2.5"/><path d="M52 64L60 72L78 54" stroke="white" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span class="logo-text">BuildPrivacyPolicy</span>
    </a>
  </div>
  <div id="step-indicator" class="step-indicator">Step 1 of 8</div>
</div>

<!-- Error Toast -->
<div id="error-toast" class="error-toast" style="display:none"></div>

<!-- Hero Section -->
<div class="hero-section">
  <div class="hero-inner">
    <h1 class="hero-title">Privacy Policy Generator</h1>
    <div class="hero-features">
      <div class="hero-feature">
        <div class="hero-feature-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <span class="hero-feature-text">Free Generate</span>
      </div>
      <div class="hero-feature">
        <div class="hero-feature-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <span class="hero-feature-text">Free Host</span>
      </div>
      <div class="hero-feature">
        <div class="hero-feature-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </div>
        <span class="hero-feature-text">Free Download</span>
      </div>
    </div>
  </div>
</div>

<!-- ======= BUILDER MODE ======= -->
<div id="builder-mode">
<div class="builder-container">

  <!-- S01: App Basics -->
  <div id="s1" data-section="1" class="form-card">
    <div class="section-header">
      <div class="section-num">1</div>
      <div>
        <div class="section-title">App Basics</div>
        <div class="section-sub">Your app, developer info, and platforms</div>
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">App name <span class="required">*</span></label>
      <input data-field="appName" placeholder="e.g. My Cool App" class="text-input" />
    </div>

    <div class="field-group">
      <label class="field-label">Developer or company name <span class="required">*</span></label>
      <input data-field="developerName" placeholder="e.g. Acme Studios" class="text-input" />
    </div>

    <div class="field-group">
      <label class="field-label">Privacy contact email <span class="required">*</span></label>
      <input data-field="privacyEmail" placeholder="privacy@example.com" type="email" class="text-input" />
    </div>

    <div class="field-group">
      <label class="field-label">Platforms <span class="required">*</span></label>
      <div class="chip-container" data-chip-field="platforms" data-mode="multi">
        <div class="chip" data-value="android_google_play">Android - Google Play</div>
        <div class="chip" data-value="android_other_store">Android - Other</div>
        <div class="chip" data-value="ios_app_store">iOS - App Store</div>
        <div class="chip" data-value="ipad_macos_other_apple">iPadOS / macOS / Other</div>
        <div class="chip" data-value="web_app">Web App / PWA</div>
        <div class="chip" data-value="other">Other</div>
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">App profile <span class="required">*</span></label>
      <div class="field-hint">We'll prefill answers based on your choice</div>
      <div class="chip-container" data-chip-field="appProfile" data-mode="single">
        <div class="chip" data-value="no_data">Simple app - no data</div>
        <div class="chip" data-value="basic_utility">Basic utility</div>
        <div class="chip" data-value="analytics_crash">Analytics &amp; crash reporting</div>
        <div class="chip" data-value="login_account">Login / account-based</div>
        <div class="chip" data-value="ads_supported">Ad-supported</div>
        <div class="chip" data-value="commerce_subscription">E-commerce / subscription</div>
        <div class="chip" data-value="social_content">Social / UGC</div>
        <div class="chip" data-value="health_fitness">Health / fitness</div>
        <div class="chip" data-value="kids_education">Kids / education</div>
        <div class="chip" data-value="finance_sensitive">Finance / sensitive</div>
        <div class="chip" data-value="custom">Custom / not sure</div>
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">What does the app do? <span class="required">*</span></label>
      <textarea data-field="appDescription" placeholder="In one sentence..." rows="2" class="text-input textarea-input"></textarea>
    </div>

    <div class="field-group">
      <label class="field-label">Regions <span class="required">*</span></label>
      <div class="chip-container" data-chip-field="regions" data-mode="multi">
        <div class="chip" data-value="worldwide">Worldwide</div>
        <div class="chip" data-value="eu_uk_ch">EU / UK / Switzerland</div>
        <div class="chip" data-value="us">United States</div>
        <div class="chip" data-value="california">California</div>
        <div class="chip" data-value="brazil">Brazil</div>
        <div class="chip" data-value="canada">Canada</div>
        <div class="chip" data-value="turkey">Turkey</div>
        <div class="chip" data-value="india">India</div>
        <div class="chip" data-value="selected_countries">Selected countries</div>
        <div class="chip" data-value="private_internal">Private / internal</div>
      </div>
    </div>
  </div>

  <!-- S02: Audience & Accounts -->
  <div data-section="2" class="form-card">
    <div class="section-header">
      <div class="section-num">2</div>
      <div>
        <div class="section-title">Audience &amp; Accounts</div>
        <div class="section-sub">Age, login, and account deletion</div>
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">Who is the app for? <span class="required">*</span></label>
      <div class="chip-container" data-chip-field="targetAudience" data-mode="single">
        <div class="chip" data-value="adults_18_plus">Adults only (18+)</div>
        <div class="chip" data-value="teens_13_plus">Users 13+</div>
        <div class="chip" data-value="general_not_child_directed">General audience</div>
        <div class="chip" data-value="mixed_with_children">Mixed, may include children</div>
        <div class="chip" data-value="child_directed">Directed to children</div>
        <div class="chip" data-value="school_or_enterprise">School / enterprise</div>
        <div class="chip" data-value="unknown">Not sure</div>
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">Does the app have user accounts? <span class="required">*</span></label>
      <div class="chip-container" data-chip-field="accountMode" data-mode="single">
        <div class="chip" data-value="no_account">No account / login</div>
        <div class="chip" data-value="optional_account">Optional account</div>
        <div class="chip" data-value="required_account">Required account</div>
        <div class="chip" data-value="third_party_login_only">Third-party login only</div>
        <div class="chip" data-value="external_account_only">External account only</div>
        <div class="chip" data-value="unknown">Not sure</div>
      </div>
    </div>

    <div id="cond-accountDeletion" class="conditional-section" style="display:none">
      <div class="field-group">
        <label class="field-label">How can users delete their account?</label>
        <div class="chip-container" data-chip-field="accountDeletionPath" data-mode="single">
          <div class="chip" data-value="full_in_app">Delete in app</div>
          <div class="chip" data-value="in_app_link_to_web">In-app link to web</div>
          <div class="chip" data-value="web_form">Web form</div>
          <div class="chip" data-value="email_request">Email request</div>
          <div class="chip" data-value="manual_support_request">Manual support</div>
          <div class="chip" data-value="not_available">Not available yet</div>
          <div class="chip" data-value="unknown">Not sure</div>
        </div>
      </div>
    </div>

    <div id="cond-deletionUrl" class="conditional-section" style="display:none">
      <div class="field-group">
        <label class="field-label">Account deletion URL</label>
        <div class="field-hint">Required by Google Play if your app has accounts</div>
        <input data-field="accountDeletionUrl" placeholder="https://example.com/delete-account" type="url" class="text-input" />
      </div>
    </div>
  </div>

  <!-- S03: Data Collection -->
  <div data-section="3" class="form-card">
    <div class="section-header">
      <div class="section-num">3</div>
      <div>
        <div class="section-title">Data Collection</div>
        <div class="section-sub">What data your app collects and why</div>
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">Does personal data leave the device? <span class="required">*</span></label>
      <div class="field-hint">Include data from your code AND any SDKs</div>
      <div class="chip-container" data-chip-field="dataLeavesDevice" data-mode="single">
        <div class="chip" data-value="no_personal_data">No personal data</div>
        <div class="chip" data-value="local_only">Stays on device</div>
        <div class="chip" data-value="yes_developer">Sent to developer</div>
        <div class="chip" data-value="yes_sdks">Sent to SDKs</div>
        <div class="chip" data-value="yes_both">Developer + third parties</div>
        <div class="chip" data-value="unknown">Not sure</div>
      </div>
    </div>

    <div id="cond-dataDetails" class="conditional-section" style="display:none">
      <div class="field-group">
        <label class="field-label">Which data types are collected? <span class="required">*</span></label>
        <div class="chip-container" data-chip-field="dataCategories" data-mode="multi">
          <div class="chip" data-value="approx_location">Approx. location</div>
          <div class="chip" data-value="precise_location">Precise location</div>
          <div class="chip" data-value="name">Name</div>
          <div class="chip" data-value="email">Email</div>
          <div class="chip" data-value="phone">Phone</div>
          <div class="chip" data-value="address">Address</div>
          <div class="chip" data-value="user_ids">User IDs</div>
          <div class="chip" data-value="payment_info">Payment info</div>
          <div class="chip" data-value="purchase_history">Purchases</div>
          <div class="chip" data-value="health_fitness">Health/fitness</div>
          <div class="chip" data-value="messages">Messages/chat</div>
          <div class="chip" data-value="photos_videos">Photos/videos</div>
          <div class="chip" data-value="audio_voice">Audio/voice</div>
          <div class="chip" data-value="files_docs">Files/docs</div>
          <div class="chip" data-value="contacts">Contacts</div>
          <div class="chip" data-value="calendar">Calendar</div>
          <div class="chip" data-value="app_activity">App activity</div>
          <div class="chip" data-value="web_browsing">Web browsing</div>
          <div class="chip" data-value="installed_apps">Installed apps</div>
          <div class="chip" data-value="crash_logs">Crash logs</div>
          <div class="chip" data-value="diagnostics">Diagnostics</div>
          <div class="chip" data-value="device_ids">Device IDs / IP</div>
          <div class="chip" data-value="government_id">Government ID</div>
          <div class="chip" data-value="biometrics">Biometrics</div>
          <div class="chip" data-value="other">Other</div>
        </div>
      </div>

      <div class="field-group">
        <label class="field-label">Why is this data used?</label>
        <div class="chip-container" data-chip-field="dataPurposes" data-mode="multi">
          <div class="chip" data-value="app_functionality">App functionality</div>
          <div class="chip" data-value="account_management">Account management</div>
          <div class="chip" data-value="analytics">Analytics</div>
          <div class="chip" data-value="crash_performance">Crash reporting</div>
          <div class="chip" data-value="customer_support">Support</div>
          <div class="chip" data-value="developer_communications">Communications</div>
          <div class="chip" data-value="advertising_marketing">Advertising</div>
          <div class="chip" data-value="personalization">Personalization</div>
          <div class="chip" data-value="payments">Payments</div>
          <div class="chip" data-value="security_fraud">Security/fraud</div>
          <div class="chip" data-value="legal_compliance">Legal compliance</div>
          <div class="chip" data-value="user_to_user">User-to-user</div>
          <div class="chip" data-value="ai_feature">AI features</div>
          <div class="chip" data-value="other">Other</div>
        </div>
      </div>

      <div class="field-group">
        <label class="field-label">Who receives this data?</label>
        <div class="chip-container" data-chip-field="dataRecipients" data-mode="multi">
          <div class="chip" data-value="none">No external recipient</div>
          <div class="chip" data-value="developer_team">Internal team</div>
          <div class="chip" data-value="cloud_hosting">Cloud hosting</div>
          <div class="chip" data-value="analytics_provider">Analytics</div>
          <div class="chip" data-value="crash_provider">Crash reporting</div>
          <div class="chip" data-value="ad_network">Ad network</div>
          <div class="chip" data-value="payment_processor">Payment processor</div>
          <div class="chip" data-value="auth_provider">Auth provider</div>
          <div class="chip" data-value="support_provider">Support</div>
          <div class="chip" data-value="messaging_provider">Messaging</div>
          <div class="chip" data-value="ai_provider">AI provider</div>
          <div class="chip" data-value="maps_location_provider">Maps/location</div>
          <div class="chip" data-value="other_users_public">Other users</div>
          <div class="chip" data-value="legal_authorities">Legal authorities</div>
          <div class="chip" data-value="business_transfer">Business transfer</div>
          <div class="chip" data-value="other">Other</div>
        </div>
      </div>
    </div>
  </div>

  <!-- S04: SDKs & Permissions -->
  <div data-section="4" class="form-card">
    <div class="section-header">
      <div class="section-num">4</div>
      <div>
        <div class="section-title">SDKs &amp; Permissions</div>
        <div class="section-sub">Third-party code and device access</div>
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">Third-party SDKs / services <span class="required">*</span></label>
      <div class="field-hint">Include all libraries in your app</div>
      <div class="chip-container" data-chip-field="thirdPartySdks" data-mode="multi">
        <div class="chip" data-value="none">None</div>
        <div class="chip" data-value="firebase_analytics">Firebase Analytics</div>
        <div class="chip" data-value="firebase_crashlytics">Firebase Crashlytics</div>
        <div class="chip" data-value="firebase_auth">Firebase Auth</div>
        <div class="chip" data-value="firebase_fcm">Firebase FCM</div>
        <div class="chip" data-value="google_mobile_ads">AdMob</div>
        <div class="chip" data-value="google_play_billing">Play Billing / IAP</div>
        <div class="chip" data-value="maps">Maps SDK</div>
        <div class="chip" data-value="social_login">Social Login</div>
        <div class="chip" data-value="meta_sdk">Meta/Facebook SDK</div>
        <div class="chip" data-value="attribution">Attribution SDK</div>
        <div class="chip" data-value="onesignal">OneSignal</div>
        <div class="chip" data-value="sentry_bugsnag">Sentry/Bugsnag</div>
        <div class="chip" data-value="stripe_paypal">Stripe/PayPal</div>
        <div class="chip" data-value="revenuecat">RevenueCat</div>
        <div class="chip" data-value="cloud_backend">Cloud Backend</div>
        <div class="chip" data-value="ai_provider">AI Provider</div>
        <div class="chip" data-value="other">Other</div>
        <div class="chip" data-value="unknown">Not sure</div>
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">Device permissions <span class="required">*</span></label>
      <div class="chip-container" data-chip-field="permissions" data-mode="multi">
        <div class="chip" data-value="none">None</div>
        <div class="chip" data-value="camera">Camera</div>
        <div class="chip" data-value="microphone">Microphone</div>
        <div class="chip" data-value="photos_media">Photos/media</div>
        <div class="chip" data-value="files_storage">Files/storage</div>
        <div class="chip" data-value="approx_location">Approx. location</div>
        <div class="chip" data-value="precise_location">Precise location</div>
        <div class="chip" data-value="background_location">Background location</div>
        <div class="chip" data-value="contacts">Contacts</div>
        <div class="chip" data-value="calendar">Calendar</div>
        <div class="chip" data-value="sms_call_logs">SMS/call logs</div>
        <div class="chip" data-value="nearby_bluetooth">Bluetooth</div>
        <div class="chip" data-value="notifications">Notifications</div>
        <div class="chip" data-value="health">Health</div>
        <div class="chip" data-value="biometrics">Biometrics</div>
        <div class="chip" data-value="motion_fitness">Motion/fitness</div>
        <div class="chip" data-value="advertising_id">Advertising ID</div>
        <div class="chip" data-value="accessibility">Accessibility</div>
        <div class="chip" data-value="installed_apps">Installed apps</div>
        <div class="chip" data-value="clipboard">Clipboard</div>
        <div class="chip" data-value="other">Other</div>
        <div class="chip" data-value="unknown">Not sure</div>
      </div>
    </div>

    <div id="cond-bgCollection" class="conditional-section" style="display:none">
      <div class="field-group">
        <label class="field-label">Background or unexpected data collection?</label>
        <div class="field-hint">Does collection happen when users wouldn't expect it?</div>
        <div class="chip-container" data-chip-field="backgroundCollection" data-mode="single">
          <div class="chip" data-value="no">No - obvious from features</div>
          <div class="chip" data-value="yes">Yes - background/not obvious</div>
          <div class="chip" data-value="sensitive_only">Sensitive permissions only</div>
          <div class="chip" data-value="unknown">Not sure</div>
        </div>
      </div>
    </div>

    <div id="cond-consent" class="conditional-section" style="display:none">
      <div class="field-group">
        <label class="field-label">Consent mechanisms used</label>
        <div class="chip-container" data-chip-field="consentControls" data-mode="multi">
          <div class="chip" data-value="os_runtime_permission">OS permission prompt</div>
          <div class="chip" data-value="in_app_prominent_disclosure">In-app disclosure</div>
          <div class="chip" data-value="checkbox_toggle">Checkbox/toggle</div>
          <div class="chip" data-value="apple_att">Apple ATT prompt</div>
          <div class="chip" data-value="cookie_consent">Cookie consent</div>
          <div class="chip" data-value="parent_consent">Parent consent</div>
          <div class="chip" data-value="school_org_consent">School/org consent</div>
          <div class="chip" data-value="not_needed">Not needed</div>
          <div class="chip" data-value="none">None currently</div>
          <div class="chip" data-value="unknown">Not sure</div>
        </div>
      </div>
    </div>
  </div>

  <!-- S05: Ads & Analytics -->
  <div data-section="5" class="form-card">
    <div class="section-header">
      <div class="section-num">5</div>
      <div>
        <div class="section-title">Ads &amp; Analytics</div>
        <div class="section-sub">Advertising, tracking, and messaging</div>
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">Ads and tracking <span class="required">*</span></label>
      <div class="chip-container" data-chip-field="adsTracking" data-mode="single">
        <div class="chip" data-value="no_ads">No ads, no tracking</div>
        <div class="chip" data-value="contextual_ads">Contextual ads only</div>
        <div class="chip" data-value="personalized_ads">Personalized ads</div>
        <div class="chip" data-value="attribution_only">Attribution only</div>
        <div class="chip" data-value="remarketing">Remarketing</div>
        <div class="chip" data-value="data_broker_or_sale_share">Data sale/share</div>
        <div class="chip" data-value="unknown">Not sure</div>
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">Marketing messages <span class="required">*</span></label>
      <div class="chip-container" data-chip-field="marketingMessages" data-mode="multi">
        <div class="chip" data-value="none">No marketing</div>
        <div class="chip" data-value="service_only">Service messages only</div>
        <div class="chip" data-value="email_marketing">Email marketing</div>
        <div class="chip" data-value="push_marketing">Push notifications</div>
        <div class="chip" data-value="sms_marketing">SMS/WhatsApp</div>
        <div class="chip" data-value="in_app_promotions">In-app promotions</div>
        <div class="chip" data-value="unknown">Not sure</div>
      </div>
    </div>
  </div>

  <!-- S06: Security & Retention -->
  <div data-section="6" class="form-card">
    <div class="section-header">
      <div class="section-num">6</div>
      <div>
        <div class="section-title">Security &amp; Retention</div>
        <div class="section-sub">How data is protected and how long it's kept</div>
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">Is data encrypted in transit? <span class="required">*</span></label>
      <div class="chip-container" data-chip-field="encryption" data-mode="single">
        <div class="chip" data-value="yes_https">Yes - HTTPS/TLS</div>
        <div class="chip" data-value="no">No</div>
        <div class="chip" data-value="not_applicable_local_only">N/A - local only</div>
        <div class="chip" data-value="unknown">Not sure</div>
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">How long is data kept? <span class="required">*</span></label>
      <div class="chip-container" data-chip-field="retention" data-mode="single">
        <div class="chip" data-value="no_server_storage">No server storage</div>
        <div class="chip" data-value="until_account_deleted">Until account deleted</div>
        <div class="chip" data-value="while_needed_backup_90">As needed + 90d backup</div>
        <div class="chip" data-value="fixed_period">Fixed period</div>
        <div class="chip" data-value="legal_business_need">Legal/business need</div>
        <div class="chip" data-value="unknown">Not sure</div>
      </div>
    </div>

    <div id="cond-retentionPeriod" class="conditional-section" style="display:none">
      <div class="field-group">
        <label class="field-label">Specify retention period</label>
        <input data-field="retentionPeriod" placeholder="e.g. 12 months, 2 years" class="text-input" />
      </div>
    </div>

    <div class="field-group">
      <label class="field-label">How can users manage their data? <span class="required">*</span></label>
      <div class="chip-container" data-chip-field="userRequestMethod" data-mode="multi">
