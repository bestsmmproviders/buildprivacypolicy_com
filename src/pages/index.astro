      dataLeavesDevice: 'yes_sdks',
      thirdPartySdks: ['firebase_analytics', 'firebase_crashlytics'],
      dataCategories: ['app_activity', 'crash_logs', 'diagnostics', 'device_ids'],
      dataPurposes: ['analytics', 'crash_performance'],
      dataRecipients: ['analytics_provider', 'crash_provider'],
      adsTracking: 'no_ads', encryption: 'yes_https', retention: 'while_needed_backup_90',
      marketingMessages: ['none'], highRiskData: ['none'], backgroundCollection: 'no'
    },
    login_account: {
      accountMode: 'required_account', dataLeavesDevice: 'yes_developer',
      dataCategories: ['email', 'user_ids'],
      dataPurposes: ['account_management', 'app_functionality'],
      dataRecipients: ['developer_team', 'cloud_hosting'],
      thirdPartySdks: ['firebase_auth', 'cloud_backend'],
      encryption: 'yes_https', retention: 'until_account_deleted',
      adsTracking: 'no_ads', marketingMessages: ['none'], highRiskData: ['none']
    },
    ads_supported: {
      dataLeavesDevice: 'yes_both',
      thirdPartySdks: ['google_mobile_ads', 'firebase_analytics', 'firebase_crashlytics'],
      dataCategories: ['device_ids', 'app_activity', 'crash_logs', 'diagnostics'],
      dataPurposes: ['advertising_marketing', 'analytics', 'crash_performance'],
      dataRecipients: ['ad_network', 'analytics_provider', 'crash_provider'],
      adsTracking: 'personalized_ads', encryption: 'yes_https',
      retention: 'while_needed_backup_90', marketingMessages: ['none'], highRiskData: ['none']
    },
    commerce_subscription: {
      accountMode: 'required_account', dataLeavesDevice: 'yes_both',
      thirdPartySdks: ['firebase_analytics', 'stripe_paypal', 'cloud_backend'],
      dataCategories: ['email', 'user_ids', 'payment_info', 'purchase_history'],
      dataPurposes: ['app_functionality', 'account_management', 'payments', 'analytics'],
      dataRecipients: ['developer_team', 'cloud_hosting', 'payment_processor', 'analytics_provider'],
      encryption: 'yes_https', retention: 'until_account_deleted',
      adsTracking: 'no_ads', marketingMessages: ['service_only'], highRiskData: ['financial_payment']
    },
    social_content: {
      accountMode: 'required_account', dataLeavesDevice: 'yes_developer',
      dataCategories: ['email', 'user_ids', 'photos_videos', 'messages'],
      dataPurposes: ['app_functionality', 'account_management', 'user_to_user'],
      dataRecipients: ['developer_team', 'cloud_hosting', 'other_users_public'],
      thirdPartySdks: ['firebase_auth', 'firebase_fcm', 'cloud_backend'],
      encryption: 'yes_https', retention: 'until_account_deleted',
      adsTracking: 'no_ads', highRiskData: ['sensitive_content']
    },
    health_fitness: {
      dataLeavesDevice: 'yes_developer',
      dataCategories: ['health_fitness', 'email', 'user_ids'],
      dataPurposes: ['app_functionality', 'account_management'],
      dataRecipients: ['developer_team', 'cloud_hosting'],
      encryption: 'yes_https', highRiskData: ['health_medical'],
      thirdPartySdks: ['cloud_backend'], retention: 'until_account_deleted'
    },
    kids_education: {
      targetAudience: 'child_directed', dataLeavesDevice: 'no_personal_data',
      thirdPartySdks: ['none'], adsTracking: 'no_ads', highRiskData: ['children'],
      marketingMessages: ['none'], permissions: ['none']
    },
    finance_sensitive: {
      accountMode: 'required_account', dataLeavesDevice: 'yes_developer',
      dataCategories: ['email', 'user_ids', 'payment_info', 'government_id'],
      dataPurposes: ['app_functionality', 'account_management', 'security_fraud', 'legal_compliance'],
      dataRecipients: ['developer_team', 'cloud_hosting', 'payment_processor'],
      encryption: 'yes_https', highRiskData: ['financial_payment', 'government_id'],
      thirdPartySdks: ['cloud_backend', 'stripe_paypal'], retention: 'legal_business_need'
    }
  };

  // ===== DOM HELPERS =====
  function $(sel) { return document.querySelector(sel); }
  function $$(sel) { return document.querySelectorAll(sel); }

  function showError(msg) {
    var toast = $('#error-toast');
    toast.textContent = msg;
    toast.style.display = 'block';
    if (errorTimeout) clearTimeout(errorTimeout);
    errorTimeout = setTimeout(function() {
      toast.style.display = 'none';
    }, 5000);
  }

  function hideError() {
    $('#error-toast').style.display = 'none';
  }

  // ===== CHIP RENDERING =====
  function updateChipUI(field) {
    var containers = $$('[data-chip-field="' + field + '"]');
    containers.forEach(function(container) {
      var mode = container.getAttribute('data-mode');
      var chips = container.querySelectorAll('.chip');
      chips.forEach(function(chip) {
        var val = chip.getAttribute('data-value');
        var isSelected;
        if (mode === 'single') {
          isSelected = state[field] === val;
        } else {
          isSelected = (state[field] || []).indexOf(val) !== -1;
        }
        if (isSelected) {
          chip.classList.add('selected');
        } else {
          chip.classList.remove('selected');
        }
      });
    });
  }

  function updateAllChips() {
    var fields = [];
    $$('[data-chip-field]').forEach(function(c) {
      var f = c.getAttribute('data-chip-field');
      if (fields.indexOf(f) === -1) fields.push(f);
    });
    fields.forEach(updateChipUI);
  }

  // ===== CONDITIONAL VISIBILITY =====
  function updateConditionals() {
    var s = state;
    var hasAccount = s.accountMode && s.accountMode !== 'no_account';
    var collectsData = s.dataLeavesDevice && ['no_personal_data', 'local_only', ''].indexOf(s.dataLeavesDevice) === -1;
    var sensitivePerms = (s.permissions || []).some(function(p) {
      return ['precise_location', 'background_location', 'contacts', 'sms_call_logs', 'health', 'camera', 'microphone', 'photos_media', 'audio_voice'].indexOf(p) !== -1;
    });
    var showChildren = ['mixed_with_children', 'child_directed', 'school_or_enterprise', 'unknown'].indexOf(s.targetAudience) !== -1;

    toggle('cond-accountDeletion', hasAccount);
    toggle('cond-deletionUrl', hasAccount && (s.platforms || []).indexOf('android_google_play') !== -1);
    toggle('cond-dataDetails', collectsData);
    toggle('cond-bgCollection', collectsData || sensitivePerms);
    toggle('cond-consent',
      s.backgroundCollection === 'yes' || s.backgroundCollection === 'sensitive_only' || s.backgroundCollection === 'unknown' ||
      s.adsTracking === 'personalized_ads' || s.adsTracking === 'remarketing' || showChildren
    );
    toggle('cond-retentionPeriod', s.retention === 'fixed_period');
    toggle('cond-storageRegion', collectsData);
    toggle('cond-children', showChildren);
  }

  function toggle(id, show) {
    var el = document.getElementById(id);
    if (el) el.style.display = show ? 'block' : 'none';
  }

  // ===== DECLARATION CHECKBOX =====
  function updateDeclUI() {
    $$('.decl-item').forEach(function(item) {
      var field = item.getAttribute('data-decl');
      if (state[field]) {
        item.classList.add('checked');
      } else {
        item.classList.remove('checked');
      }
    });
  }

  // ===== TEXT INPUT SYNC =====
  function syncTextInputs() {
    $$('input[data-field], textarea[data-field]').forEach(function(el) {
      var f = el.getAttribute('data-field');
      if (state[f] !== undefined && el.value !== state[f]) {
        el.value = state[f];
      }
    });
  }

  // ===== APPLY PRESET =====
  function applyPreset(profile) {
    if (!presets[profile]) return;
    var p = presets[profile];
    for (var key in p) {
      if (p.hasOwnProperty(key)) {
        state[key] = Array.isArray(p[key]) ? p[key].slice() : p[key];
      }
    }
    updateAllChips();
    updateConditionals();
    updateDeclUI();
    syncTextInputs();
  }

  // ===== EVENT DELEGATION =====
  document.addEventListener('click', function(e) {
    // Chip click
    var chip = e.target.closest('.chip');
    if (chip) {
      var container = chip.closest('[data-chip-field]');
      if (!container) return;
      var field = container.getAttribute('data-chip-field');
      var mode = container.getAttribute('data-mode');
      var val = chip.getAttribute('data-value');
      if (!field || !val) return;

      hideError();

      if (mode === 'single') {
        // Toggle: click selected => deselect, click other => select
        state[field] = state[field] === val ? '' : val;
        // If appProfile changed, apply preset
        if (field === 'appProfile' && state[field]) {
          applyPreset(state[field]);
        }
      } else {
        // Multi-select with exclusive logic
        var excl = ['none', 'not_needed'];
        var cur = (state[field] || []).slice();
        if (excl.indexOf(val) !== -1) {
          // Clicking exclusive: toggle it, clear others
          state[field] = cur.indexOf(val) !== -1 ? [] : [val];
        } else {
          // Clicking non-exclusive: remove any exclusive items first
          var filtered = cur.filter(function(x) { return excl.indexOf(x) === -1; });
          var idx = filtered.indexOf(val);
          if (idx !== -1) {
            filtered.splice(idx, 1);
          } else {
            filtered.push(val);
          }
          state[field] = filtered;
        }
      }

      updateChipUI(field);
      updateConditionals();
      return;
    }

    // Declaration checkbox click
    var declItem = e.target.closest('.decl-item');
    if (declItem) {
      var declField = declItem.getAttribute('data-decl');
      if (declField) {
        hideError();
        state[declField] = !state[declField];
        updateDeclUI();
      }
      return;
    }

    // Back to edit
    if (e.target.closest('#back-to-edit')) {
      $('#results-mode').style.display = 'none';
      $('#builder-mode').style.display = 'block';
      $('#step-indicator').style.display = 'block';
      window.scrollTo({ top: 0, behavior: 'smooth' });
      return;
    }

    // Generate button
    if (e.target.closest('#generate-btn')) {
      handleGenerate();
      return;
    }

    // Copy button
    if (e.target.closest('#btn-copy')) {
      handleCopy();
      return;
    }

    // Download HTML
    if (e.target.closest('#btn-dl-html')) {
      handleDownloadHtml();
      return;
    }

    // Download Text
    if (e.target.closest('#btn-dl-text')) {
      handleDownloadText();
      return;
    }
  });

  // Text input handling
  document.addEventListener('input', function(e) {
    var field = e.target.getAttribute('data-field');
    if (field && state.hasOwnProperty(field)) {
      state[field] = e.target.value;
      hideError();
    }
  });

  // ===== TURNSTILE CALLBACK =====
  window.onTurnstileSuccess = function(token) {
    turnstileToken = token;
  };

  // ===== GENERATE =====
  function handleGenerate() {
    var s = state;

    // Validation
    if (!s.appName || !s.appName.trim()) { showError('Please enter the app name'); return; }
    if (!s.developerName || !s.developerName.trim()) { showError('Please enter the developer name'); return; }
    if (!s.privacyEmail || !s.privacyEmail.trim()) { showError('Please enter a privacy email'); return; }
    if (!s.platforms || !s.platforms.length) { showError('Please select at least one platform'); return; }
    if (!s.appDescription || !s.appDescription.trim()) { showError('Please describe what the app does'); return; }
    if (!s.regions || !s.regions.length) { showError('Please select at least one region'); return; }
    if (!s.declAccurate || !s.declSdks || !s.declLegal || !s.declUpdate) {
      showError('Please check all declaration boxes in Step 8');
      return;
    }

    var btn = $('#generate-btn');
    btn.disabled = true;
    btn.textContent = 'Generating...';

    var payload = {
      appName: s.appName.trim(),
      developerName: s.developerName.trim(),
      privacyEmail: s.privacyEmail.trim(),
      platforms: s.platforms,
      appProfile: s.appProfile,
      appDescription: s.appDescription.trim(),
      regions: s.regions,
      targetAudience: s.targetAudience,
      accountMode: s.accountMode,
      accountDeletionPath: s.accountDeletionPath,
      accountDeletionUrl: s.accountDeletionUrl,
      dataLeavesDevice: s.dataLeavesDevice,
      dataCategories: s.dataCategories,
      dataPurposes: s.dataPurposes,
      dataRecipients: s.dataRecipients,
      thirdPartySdks: s.thirdPartySdks,
      permissions: s.permissions,
      backgroundCollection: s.backgroundCollection,
      consentControls: s.consentControls,
      adsTracking: s.adsTracking,
      marketingMessages: s.marketingMessages,
      encryption: s.encryption,
      retention: s.retention,
      retentionPeriod: s.retentionPeriod,
      userRequestMethod: s.userRequestMethod,
      storageRegion: s.storageRegion,
      highRiskData: s.highRiskData,
      childrenCompliance: s.childrenCompliance,
      aiUse: s.aiUse,
      outputs: s.outputs,
      language: s.language,
      declAccurate: s.declAccurate,
      declSdks: s.declSdks,
      declLegal: s.declLegal,
      declUpdate: s.declUpdate,
      turnstileToken: turnstileToken
    };

    fetch(API_BASE + '/api/generate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    .then(function(res) {
      if (!res.ok) {
        return res.json().then(function(data) {
          throw new Error(data.error || data.message || 'Generation failed');
        }).catch(function(parseErr) {
          if (parseErr.message && parseErr.message !== 'Generation failed') throw parseErr;
          throw new Error('Server error (' + res.status + ')');
        });
      }
      return res.json();
    })
    .then(function(data) {
      btn.disabled = false;
      btn.textContent = 'Generate Privacy Policy';

      resultData.policyHtml = data.policyHtml || '';
      resultData.policyText = data.policyText || '';
      resultData.standaloneHtml = data.standaloneHtml || data.policyHtml || '';
      resultData.googlePlayHtml = data.googlePlayHtml || '';
      resultData.warnings = data.warnings || [];
      resultData.policyId = data.uuid || '';

      showResults();
    })
    .catch(function(err) {
      btn.disabled = false;
      btn.textContent = 'Generate Privacy Policy';
      showError(err.message || 'Generation failed. Please try again.');
    });
  }

  // ===== SHOW RESULTS =====
  function showResults() {
    $('#builder-mode').style.display = 'none';
    $('#step-indicator').style.display = 'none';
    $('#results-mode').style.display = 'block';

    // Policy preview
    if (resultData.policyHtml) {
      $('#policy-preview').innerHTML = resultData.policyHtml;
    } else if (resultData.policyText) {
      $('#policy-preview').textContent = resultData.policyText;
    }

    // Hosted URL
    if (resultData.policyId) {
      var hostedCard = $('#hosted-url-card');
      hostedCard.style.display = 'block';
      var hostedUrl = API_BASE + '/policy/' + resultData.policyId;
      $('#result-hosted-url').textContent = hostedUrl;
      $('#result-hosted-url').href = hostedUrl;
    }

    // Google Play Helper
    if (resultData.googlePlayHtml && state.outputs.indexOf('google_play_data_safety_helper') !== -1) {
      $('#google-play-card').style.display = 'block';
      $('#google-play-content').innerHTML = resultData.googlePlayHtml;
    }

    // Warnings
    if (resultData.warnings.length > 0) {
      var warningsEl = $('#result-warnings');
      warningsEl.style.display = 'block';
      var listEl = $('#warnings-list');
      listEl.innerHTML = '';
      resultData.warnings.forEach(function(w) {
        var div = document.createElement('div');
        div.style.cssText = 'font-size:13px;color:#78350F;margin-bottom:4px;padding-left:16px;position:relative';
        div.innerHTML = '<span style="position:absolute;left:0">•</span>' + escapeHtml(w);
        listEl.appendChild(div);
      });
    }

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // ===== EXPORT HANDLERS =====
  function handleCopy() {
    var url = $('#result-hosted-url').href;
    navigator.clipboard.writeText(url).then(function() {
      var btn = $('#btn-copy');
      btn.textContent = 'Copied!';
      setTimeout(function() { btn.textContent = 'Copy URL'; }, 2500);
    }).catch(function() {});
  }

  function handleDownloadHtml() {
    var html = resultData.standaloneHtml || resultData.policyHtml;
    if (!html) return;
    var blob = new Blob([html], { type: 'text/html' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'privacy-policy-' + (state.appName || 'app').toLowerCase().replace(/[^a-z0-9]+/g, '-') + '.html';
    a.click();
    URL.revokeObjectURL(url);
  }

  function handleDownloadText() {
    var text = resultData.policyText;
    if (!text) return;
    var blob = new Blob([text], { type: 'text/plain' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'privacy-policy-' + (state.appName || 'app').toLowerCase().replace(/[^a-z0-9]+/g, '-') + '.txt';
    a.click();
    URL.revokeObjectURL(url);
  }

  // ===== INTERSECTION OBSERVER FOR STEP INDICATOR =====
  var observer = new IntersectionObserver(function(entries) {
    for (var i = 0; i < entries.length; i++) {
      if (entries[i].isIntersecting && entries[i].intersectionRatio > 0.15) {
        var step = parseInt(entries[i].target.getAttribute('data-section'));
        if (step) {
          $('#step-indicator').textContent = 'Step ' + step + ' of 8';
        }
      }
    }
  }, { threshold: 0.15, rootMargin: '-60px 0px 0px 0px' });

  // Observe sections after DOM is ready
  setTimeout(function() {
    $$('[data-section]').forEach(function(el) {
      observer.observe(el);
    });
  }, 300);

  // Initialize: set default selected chips
  updateAllChips();
  updateConditionals();
  updateDeclUI();

})();
</script>

